%   data: {"layout":"inline","rightPanelPercent":37.4}
%---
%[task:43b8]
%   data: {"appState":"{\"path\":\"C:\\\\Users\\\\heero\\\\Documents\\\\Local Repositories\\\\UWCC Structural Analysis\\\\\",\"filename\":\"HullCoordinates.csv\",\"currentImportTask\":\"matlab.internal.importlivetask.TextImportTask\",\"durationIdx\":[false,false,false,false],\"lastImportOptions\":{\"SelectedVariableNames\":[\"LongitudinalPosition\",\"Offset\",\"Height\",\"Side\"],\"VariableNames\":[\"LongitudinalPosition\",\"Offset\",\"Height\",\"Side\"],\"VariableOptions\":[{\"Name\":\"LongitudinalPosition\",\"Type\":\"double\",\"FillValue\":NaN,\"TreatAsMissing\":[],\"QuoteRule\":\"remove\",\"Prefixes\":[],\"Suffixes\":[],\"EmptyFieldRule\":\"missing\",\"ExponentCharacter\":\"eEdD\",\"ThousandsSeparator\":\"\",\"TrimNonNumeric\":false,\"NumberSystem\":\"decimal\",\"DecimalSeparator\":\".\"},{\"Name\":\"Offset\",\"Type\":\"double\",\"FillValue\":NaN,\"TreatAsMissing\":[],\"QuoteRule\":\"remove\",\"Prefixes\":[],\"Suffixes\":[],\"EmptyFieldRule\":\"missing\",\"ExponentCharacter\":\"eEdD\",\"ThousandsSeparator\":\"\",\"TrimNonNumeric\":false,\"NumberSystem\":\"decimal\",\"DecimalSeparator\":\".\"},{\"Name\":\"Height\",\"Type\":\"double\",\"FillValue\":NaN,\"TreatAsMissing\":[],\"QuoteRule\":\"remove\",\"Prefixes\":[],\"Suffixes\":[],\"EmptyFieldRule\":\"missing\",\"ExponentCharacter\":\"eEdD\",\"ThousandsSeparator\":\"\",\"TrimNonNumeric\":false,\"NumberSystem\":\"decimal\",\"DecimalSeparator\":\".\"},{\"Name\":\"Side\",\"Type\":\"categorical\",\"FillValue\":null,\"TreatAsMissing\":[],\"QuoteRule\":\"remove\",\"Prefixes\":[],\"Suffixes\":[],\"EmptyFieldRule\":\"auto\",\"Categories\":[],\"Protected\":false,\"Ordinal\":false}],\"VariableTypes\":[\"double\",\"double\",\"double\",\"categorical\"],\"ImportErrorRule\":\"fill\",\"MissingRule\":\"fill\",\"PreserveVariableNames\":false,\"VariableNamingRule\":\"modify\",\"DataLines\":[2,Infinity],\"VariableNamesLine\":0,\"RowNamesColumn\":0,\"VariableUnitsLine\":0,\"VariableDescriptionsLine\":0,\"ExtraColumnsRule\":\"ignore\",\"EmptyLineRule\":\"read\",\"Whitespace\":\"\\\\b\\\\t \",\"LineEnding\":[\"\\\\n\",\"\\\\r\",\"\\\\r\\\\n\"],\"CommentStyle\":[],\"Encoding\":\"\",\"ConsecutiveDelimitersRule\":\"split\",\"LeadingDelimitersRule\":\"keep\",\"TrailingDelimitersRule\":\"keep\",\"Delimiter\":[\",\"]},\"lastCode\":\"% Set up the Import Options and import the data\\nopts = delimitedTextImportOptions(\\\"NumVariables\\\", 4);\\n\\n% Specify range and delimiter\\nopts.DataLines = [2, Inf];\\nopts.Delimiter = \\\",\\\";\\n\\n% Specify column names and types\\nopts.VariableNames = [\\\"LongitudinalPosition\\\", \\\"Offset\\\", \\\"Height\\\", \\\"Side\\\"];\\nopts.VariableTypes = [\\\"double\\\", \\\"double\\\", \\\"double\\\", \\\"categorical\\\"];\\n\\n% Specify file level properties\\nopts.ExtraColumnsRule = \\\"ignore\\\";\\nopts.EmptyLineRule = \\\"read\\\";\\n\\n% Specify variable properties\\nopts = setvaropts(opts, \\\"Side\\\", \\\"EmptyFieldRule\\\", \\\"auto\\\");\\n\\n% Import the data\\nHullCoordinates = readtable(\\\"C:\\\\Users\\\\heero\\\\Documents\\\\Local Repositories\\\\UWCC Structural Analysis\\\\HullCoordinates.csv\\\", opts);\\n\",\"codeContainsImportOptions\":true,\"lastOutputType\":\"table\",\"lastVarName\":\"HullCoordinates\",\"showImportData\":false,\"returnImportOptions\":false,\"showImportOptions\":false,\"useVarsFromFile\":true}","autorun":"1","collapsed":"1","outputs":"HullCoordinates","run":"section","taskClassDefFile":"matlab.internal.importlivetask.ImportTask","uniqueId":"matlab\/ImportData","variablesMap":"{\"opts\":\"opts\",\"HullCoordinates\":\"HullCoordinates\"}","view":"controls-only"}
%---
%[control:editfield:77f0]
%   data: {"defaultValue":0,"label":"rho_struct","run":"Section","valueType":"Double"}
%---
%[control:editfield:149e]
%   data: {"defaultValue":0,"label":"fc","run":"Section","valueType":"Double"}
%---
%[control:editfield:4eda]
%   data: {"defaultValue":0,"label":"ft","run":"Section","valueType":"Double"}
%---
%[control:editfield:85a5]
%   data: {"defaultValue":0,"label":"live_factor","run":"Section","valueType":"Double"}
%---
%[control:editfield:683b]
%   data: {"defaultValue":0,"label":"dead_factor","run":"Section","valueType":"Double"}
%---
%[control:editfield:3b8d]
%   data: {"defaultValue":0,"label":"cable_loss","run":"Section","valueType":"Double"}
%---
%[control:editfield:68b2]
%   data: {"defaultValue":0,"label":"phi_fc","run":"Section","valueType":"Double"}
%---
%[control:editfield:979a]
%   data: {"defaultValue":0,"label":"male_weight","run":"Section","valueType":"Double"}
%---
%[control:editfield:6f60]
%   data: {"defaultValue":0,"label":"female_weight","run":"Section","valueType":"Double"}
%---
%[control:slider:4be4]
%   data: {"defaultValue":2,"label":"num_stands","max":8,"min":1,"run":"Section","runOn":"ValueChanging","step":1}
%---
%[control:editfield:535a]
%   data: {"defaultValue":0,"label":"stand_distance","run":"Section","valueType":"Double"}
%---
%[control:editfield:0e83]
%   data: {"defaultValue":0,"label":"x_interp","run":"Section","valueType":"Double"}
%---
%[control:slider:3819]
%   data: {"defaultValue":10,"label":"draftGuess","max":20,"min":0,"run":"Nothing","runOn":"ValueChanging","step":0.1}
%---
%[control:editfield:1b51]
%   data: {"defaultValue":0,"label":"draft_min","run":"Section","valueType":"Double"}
%---
%[control:checkbox:04ec]
%   data: {"defaultValue":false,"label":"Run Solver","run":"Nothing"}
%---
%[control:slider:33a0]
%   data: {"defaultValue":1,"label":"cableSpacing","max":4,"min":0.5,"run":"Section","runOn":"ValueChanging","step":0.5}
%---
%[control:slider:6e00]
%   data: {"defaultValue":8,"label":"num_cables","max":12,"min":2,"run":"Section","runOn":"ValueChanging","step":2}
